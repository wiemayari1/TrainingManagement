# ============================================================
# FICHIER : .env.example
# Copier vers .env et remplir TOUTES les valeurs
# NE JAMAIS COMMITTER .env dans git
# ============================================================

# ── Backend ──────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=CHANGER_AVEC_UNE_VALEUR_ALEATOIRE_DE_64_CHARS_MINIMUM

# Durée de validité du token en millisecondes (1h = 3600000)
JWT_EXPIRATION=3600000

# Base de données
MYSQL_USER=training_user
MYSQL_PASSWORD=CHANGER_MOT_DE_PASSE_BD
DATASOURCE_URL=jdbc:mysql://localhost:3306/training_db?useSSL=true&serverTimezone=UTC

# Email SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=votre-email@gmail.com
MAIL_PASSWORD=votre-app-password-gmail
MAIL_FROM_NAME=Excellent Training

# URLs
FRONTEND_URL=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8081/api
